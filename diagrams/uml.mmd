classDiagram
    class Owner {
        +str name
        +int age
        +str gender
        +List~Pet~ pets
        +addPet(pet) None
        +getName() str
        +getPets() List~Pet~
    }

    class Pet {
        +str name
        +str type
        +str color
        +int hunger
        +List~Task~ tasks
        +getName() str
        +addFood(amount) None
        +addTask(task) None
        +getTasks() List~Task~
    }

    class Task {
        +str name
        +int duration
        +str priority
        +bool completed
        +getPriority() str
        +markComplete() None
    }

    class Scheduler {
        +int timeAvailable
        +generatePlan(pet) List~Task~
        +getPlan() List~Task~
        +addTask(task) None
    }

    Owner "1" --> "0..*" Pet : owns
    Pet "1" --> "0..*" Task : has
    Scheduler "1" ..> "1" Pet : plans for
    Scheduler "1" o-- "0..*" Task : schedules
